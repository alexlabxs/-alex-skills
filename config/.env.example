# ============================================
# alex-skills 环境变量配置示例
# ============================================
# 复制此文件到 ~/.baoyu-skills/.env 并按需修改
# ============================================

# DashScope API Key（用于通义万相图片生成）
# yiran-wechat-prepare 生成配图时需要
DASHSCOPE_API_KEY=sk-ds-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 微信公众平台凭证（用于 baoyu-post-to-wechat）
WECHAT_APP_ID=wx0000000000000000
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
